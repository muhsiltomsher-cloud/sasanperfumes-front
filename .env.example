# Sasan Perfumes - Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# WordPress/WooCommerce Backend Configuration
# ===========================================

# WordPress GraphQL endpoint URL
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://cms.shapehive.com/graphql

# Site URL (your frontend URL — Vercel deployment or custom domain)
NEXT_PUBLIC_SITE_URL=https://shapehive.com

# Optional Sasan Perfumes brand assets
# Leave empty to show the text logo in the copied frontend.
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_BRAND_FAVICON_URL=
NEXT_PUBLIC_USE_BACKEND_BRAND_ASSETS=false

# WooCommerce API URL (your WordPress/WooCommerce backend URL)
# This is used for all WooCommerce Store API and REST API requests
NEXT_PUBLIC_WC_API_URL=https://cms.shapehive.com

# ===========================================
# WooCommerce REST API Credentials
# Required for wishlist functionality (TI WooCommerce Wishlist plugin)
# ===========================================

# WooCommerce Consumer Key (from WooCommerce > Settings > Advanced > REST API)
# Create a key with Read/Write permissions
WC_CONSUMER_KEY=ck_your_consumer_key_here

# WooCommerce Consumer Secret
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# ===========================================
# Google Sign-In Configuration
# ===========================================

# Google OAuth Client ID (from Google Cloud Console)
# Required for Google Sign-In button on login/register pages
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Secret key for deriving social login passwords (optional)
# Falls back to WC_CONSUMER_SECRET if not set
# SOCIAL_LOGIN_SECRET=your_random_secret_here

# ===========================================
# Payment Gateway Configuration
# ===========================================

# MyFatoorah Payment Gateway
# Get your API key from MyFatoorah merchant portal
MYFATOORAH_API_KEY=your_myfatoorah_api_key_here
# Set to "true" to use MyFatoorah test/sandbox environment
MYFATOORAH_TEST_MODE=false
# Country code for MyFatoorah API (determines which API endpoint to use)
# Supported values:
#   - AE/UAE (UAE): Uses api-ae.myfatoorah.com
#   - SA/SAU (Saudi Arabia): Uses api-sa.myfatoorah.com
#   - QA/QAT (Qatar): Uses api-qa.myfatoorah.com
#   - EG/EGY (Egypt): Uses api-eg.myfatoorah.com
#   - PORTAL/MAIN/KW/KWT/BH/BHR/JO/JOR/OM/OMN: Uses api-ae.myfatoorah.com
# Note: The old api.myfatoorah.com URL has been deprecated by MyFatoorah as of Feb 28, 2026.
# All regions now use country-specific endpoints (e.g. api-ae.myfatoorah.com for UAE).
MYFATOORAH_COUNTRY=AE

# Tabby Payment Gateway (Buy Now Pay Later)
# Get your credentials from Tabby merchant portal
TABBY_SECRET_KEY=your_tabby_secret_key_here
TABBY_MERCHANT_CODE=your_tabby_merchant_code_here

# ===========================================
# Analytics & Tracking
# ===========================================

# Google Ads Conversion ID (for Google Ads remarketing/conversion tracking)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Pinterest Domain Verification
NEXT_PUBLIC_PINTEREST_DOMAIN_VERIFY=

# Omnisend Email Marketing
# Brand ID from Omnisend Settings (used for abandoned cart tracking)
# Get from: https://app.omnisend.com/ > Settings > Your Brand ID
NEXT_PUBLIC_OMNISEND_BRAND_ID=your_omnisend_brand_id_here

# Omnisend API Key (server-side only, used for REST API cart sync)
# Required for abandoned cart automation workflow to trigger correctly.
# Get from: https://app.omnisend.com/ > Store Settings > API Keys
OMNISEND_API_KEY=your_omnisend_api_key_here

# Tamara Payment Gateway (Buy Now Pay Later)
# Get your credentials from Tamara merchant portal
TAMARA_API_TOKEN=your_tamara_api_token_here
# Public key for Tamara promo widgets (required for widget display)
NEXT_PUBLIC_TAMARA_PUBLIC_KEY=your_tamara_public_key_here
# Country code for Tamara widget (SA for Saudi Arabia, AE for UAE)
# This is required for the Tamara widget to load correctly
NEXT_PUBLIC_TAMARA_COUNTRY=AE
